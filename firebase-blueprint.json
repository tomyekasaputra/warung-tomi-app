{
  "entities": {
    "UserPhoto": {
      "title": "User Photo",
      "description": "Stores user profile photos as base64 strings",
      "type": "object",
      "properties": {
        "nama": { "type": "string", "description": "The name of the user (primary identifier)" },
        "photo": { "type": "string", "description": "Base64 encoded photo data" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["nama", "photo", "updatedAt"]
    }
  },
  "firestore": {
    "/userPhotos/{nama}": {
      "schema": "UserPhoto",
      "description": "Collection of user profile photos"
    }
  }
}
