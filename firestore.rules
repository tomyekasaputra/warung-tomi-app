rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\s]+$');
    }

    function isValidUserPhoto(data) {
      return data.keys().hasAll(['nama', 'photo', 'updatedAt']) 
        && data.keys().size() == 3
        && data.nama is string && data.nama.size() <= 200
        && data.photo is string && data.photo.size() <= 1048576 // 1MB limit
        && data.updatedAt is timestamp;
    }

    match /userPhotos/{nama} {
      allow get: if isValidId(nama);
      allow list: if false; // Prevention of scraping
      
      allow create: if isValidId(nama) 
        && isValidUserPhoto(request.resource.data)
        && request.resource.data.nama == nama;
        
      allow update: if isValidId(nama)
        && isValidUserPhoto(request.resource.data)
        && request.resource.data.nama == nama
        && request.resource.data.nama == resource.data.nama; // Name is immutable
        
      allow delete: if false; // Photos shouldn't be deleted by clients for now
    }
  }
}
